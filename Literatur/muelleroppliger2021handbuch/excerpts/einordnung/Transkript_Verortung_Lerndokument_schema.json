{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/transkript_verortung_lerndokument.schema.json",
  "title": "Transkript Verortung Lerndokument",
  "type": "object",
  "required": [
    "dataset_meta",
    "source_context",
    "summary",
    "records",
    "issues"
  ],
  "properties": {
    "dataset_meta": {
      "type": "object",
      "required": [
        "dataset_id",
        "dataset_version",
        "encoding",
        "language",
        "design_goal"
      ],
      "properties": {
        "dataset_id": {
          "type": "string"
        },
        "dataset_version": {
          "type": "string"
        },
        "created_from": {
          "type": "string"
        },
        "export_format": {
          "type": "string",
          "const": "json"
        },
        "encoding": {
          "type": "string"
        },
        "language": {
          "type": "string"
        },
        "generator": {
          "type": "string"
        },
        "created_on": {
          "type": "string"
        },
        "design_goal": {
          "type": "string"
        }
      }
    },
    "source_context": {
      "type": "object"
    },
    "normalization_rules": {
      "type": "object"
    },
    "lookups": {
      "type": "object"
    },
    "overview": {
      "type": "object"
    },
    "summary": {
      "type": "object",
      "required": [
        "total_records"
      ],
      "properties": {
        "total_records": {
          "type": "integer"
        },
        "by_primary_target": {
          "type": "object"
        },
        "by_priority": {
          "type": "object"
        },
        "by_current_status": {
          "type": "object"
        },
        "by_transcript_coverage": {
          "type": "object"
        },
        "duplicates_across_uploads": {
          "type": "integer"
        },
        "requires_source_before_use": {
          "type": "integer"
        }
      }
    },
    "indexes": {
      "type": "object"
    },
    "records": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "record_id",
          "handbuch_part",
          "chapter",
          "pages",
          "placement",
          "priority",
          "confidence"
        ],
        "properties": {
          "record_id": {
            "type": "string",
            "pattern": "^HB-[0-9]{3}$"
          },
          "source_workbook_row": {
            "type": "integer"
          },
          "handbuch_part": {
            "type": "object",
            "required": [
              "code",
              "title"
            ],
            "properties": {
              "code": {
                "type": "string"
              },
              "title": {
                "type": "string"
              }
            }
          },
          "source_files": {
            "type": "array"
          },
          "is_duplicate_across_uploads": {
            "type": "boolean"
          },
          "chapter": {
            "type": "object",
            "required": [
              "title",
              "authors"
            ],
            "properties": {
              "authors_raw": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "authors": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "title": {
                "type": "string"
              }
            }
          },
          "source_work_ref": {
            "type": "object"
          },
          "pages": {
            "type": "object",
            "required": [
              "start",
              "end",
              "count"
            ],
            "properties": {
              "start": {
                "type": [
                  "integer",
                  "null"
                ]
              },
              "end": {
                "type": [
                  "integer",
                  "null"
                ]
              },
              "count": {
                "type": [
                  "integer",
                  "null"
                ]
              },
              "derivation_note": {
                "type": [
                  "string",
                  "null"
                ]
              }
            }
          },
          "transcript_status": {
            "type": "object"
          },
          "placement": {
            "type": "object"
          },
          "tex_recommendation": {
            "type": "object"
          },
          "why_here": {
            "type": [
              "string",
              "null"
            ]
          },
          "integration_hint": {
            "type": [
              "string",
              "null"
            ]
          },
          "priority": {
            "type": "object",
            "required": [
              "code",
              "rank"
            ],
            "properties": {
              "code": {
                "type": "string",
                "enum": [
                  "A",
                  "B",
                  "C"
                ]
              },
              "label": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "rank": {
                "type": [
                  "integer",
                  "null"
                ]
              }
            }
          },
          "confidence": {
            "type": [
              "number",
              "null"
            ]
          },
          "evidence": {
            "type": "object"
          },
          "quality_flags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "raw_row_snapshot": {
            "type": "object"
          }
        }
      }
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "issue_id",
          "problem_type",
          "severity",
          "observation",
          "impact",
          "recommendation"
        ],
        "properties": {
          "issue_id": {
            "type": "string"
          },
          "problem_type": {
            "type": "string"
          },
          "problem_type_code": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": [
              "info",
              "medium",
              "high"
            ]
          },
          "location_or_scope": {
            "type": [
              "string",
              "null"
            ]
          },
          "observation": {
            "type": "string"
          },
          "impact": {
            "type": "string"
          },
          "recommendation": {
            "type": "string"
          }
        }
      }
    }
  }
}